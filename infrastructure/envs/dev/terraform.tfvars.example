# AWS Configuration
region     = "ap-southeast-1"


# Environment
env = "dev"

# Networking
vpc_cidr = "10.0.0.0/16"

# Compute (t4g.micro for Dev)
instance_type = "t4g.micro"

# Database (PostgreSQL for Dev)
db_engine         = "postgres"
db_port           = 5432
allocated_storage = 20
db_instance_class = "db.t3.micro"
db_name           = "dev_inventory_db"
db_user           = "dev_db_admin"


