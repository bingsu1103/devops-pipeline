{% if ssl_enabled | default(false) %}
server {
    listen 80;
    server_name {{ domain_name | default('localhost') }};

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name {{ domain_name | default('localhost') }};

    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    {% if proxy_mode | default('frontend') == 'backend' %}
    location / {
        proxy_pass http://{{ backend_host | default('localhost') }}:{{ backend_port | default('7070') }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    {% else %}
    # Router cho Backend API
    location /api {
        proxy_pass http://{{ backend_host | default('localhost') }}:{{ backend_port | default('7070') }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Router cho Frontend (Tat ca cac path khac)
    location / {
        proxy_pass http://localhost:{{ frontend_port | default('3000') }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    {% endif %}
}
{% else %}
server {
    listen 80;
    server_name {{ domain_name | default('localhost') }};

    {% if proxy_mode | default('frontend') == 'backend' %}
    location / {
        proxy_pass http://{{ backend_host | default('localhost') }}:{{ backend_port | default('7070') }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    {% else %}
    # Router cho Backend API
    location /api {
        proxy_pass http://{{ backend_host | default('localhost') }}:{{ backend_port | default('7070') }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Router cho Frontend (Tat ca cac path khac)
    location / {
        proxy_pass http://localhost:{{ frontend_port | default('3000') }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    {% endif %}
}
{% endif %}

