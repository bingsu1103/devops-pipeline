pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-creds'
        DOCKERHUB_USER = 'bingsu1103'
        TAG = "build-${env.BUILD_NUMBER}"
        // Hỗ trợ cả Intel Mac (/usr/local/bin) và Apple Silicon Mac (/opt/homebrew/bin)
        PATH = "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Applications/Docker.app/Contents/Resources/bin:${env.PATH}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build Artifacts') {
            steps {
                dir('backend') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    sh "chmod +x ci-cd/scripts/*.sh"
                    sh "./ci-cd/scripts/build.sh ${TAG}"
                }
            }
        }

        stage('Push DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        sh "docker login -u ${USER} -p ${PASS}"
                        sh "./ci-cd/scripts/push.sh ${TAG}"
                    }
                }
            }
        }

        stage('Infrastructure Provisioning') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key', variable: 'AWS_ACCESS'),
                    string(credentialsId: 'aws-secret-key', variable: 'AWS_SECRET')
                ]) {
                    dir('infrastructure/envs/dev') {
                        sh 'terraform init'
                        sh "export TF_VAR_access_key=${AWS_ACCESS} && export TF_VAR_secret_key=${AWS_SECRET} && terraform apply -auto-approve"
                        
                        script {
                            // Lay IP tu Terraform Output
                            def backend_ip = sh(script: "terraform output -raw backend_public_ip", returnStdout: true).trim()
                            def frontend_ip = sh(script: "terraform output -raw frontend_public_ip", returnStdout: true).trim()
                            def rds_endpoint_full = sh(script: "terraform output -raw rds_endpoint", returnStdout: true).trim()
                            def rds_host = rds_endpoint_full.split(":")[0]

                            echo "Backend IP: ${backend_ip}"
                            echo "Frontend IP: ${frontend_ip}"
                            echo "RDS Host: ${rds_host}"

                            // Cap nhat file inventory cua Ansible
                            dir('../../../ansible') {
                                sh "sed -i '' 's/backend_server ansible_host=[^ ]*/backend_server ansible_host=${backend_ip}/g' inventory/dev.ini"
                                sh "sed -i '' 's/frontend_server ansible_host=[^ ]*/frontend_server ansible_host=${frontend_ip}/g' inventory/dev.ini"
                                sh "sed -i '' 's/db_host=.*/db_host=${rds_host}/g' inventory/dev.ini"
                                sh "sed -i '' 's/db_name=.*/db_name=devops_db/g' inventory/dev.ini"
                                sh "sed -i '' 's/db_password=.*/db_password=dev-db-pass/g' inventory/dev.ini"
                                
                                echo "--- Updated Ansible Inventory ---"
                                sh "cat inventory/dev.ini"
                            }
                        }
                    }
                }
            }
        }

        stage('Configuration & Deploy') {
            steps {
                script {
                    // Update Tag cho Ansible
                    dir('ansible') {
                        sh "ansible-playbook -i inventory/dev.ini playbooks/setup.yml"
                        sh "ansible-playbook -i inventory/dev.ini playbooks/deploy.yml --extra-vars 'image_tag=${TAG}'"
                    }
                    
                    // Chạy Kubernetes nếu cần
                    /* 
                    dir('k8s') {
                        sh "kubectl apply -f namespace.yaml"
                        sh "kubectl apply -f backend/"
                        sh "kubectl apply -f frontend/"
                        sh "kubectl apply -f ingress.yaml"
                    }
                    */
                }
            }
        }
    }

    post {
        always {
            echo "--- Pipeline completed ---"
        }
        success {
            echo "--- Build successful! ---"
        }
        failure {
            echo "--- Build failed. Please check logs. ---"
        }
    }
}
