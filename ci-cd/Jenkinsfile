pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-creds' // Cấu hình trong Jenkins Credentials
        DOCKERHUB_USER = 'bingsu1103'
        TAG = "build-${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build Artifacts') {
            parallel {
                stage('Build Backend') {
                    steps {
                        dir('backend') {
                            sh './mvnw clean package -DskipTests'
                        }
                    }
                }
                stage('Build Frontend') {
                    steps {
                        dir('frontend') {
                            sh 'npm install && npm run build'
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    sh "chmod +x ci-cd/scripts/*.sh"
                    sh "./ci-cd/scripts/build.sh ${TAG}"
                }
            }
        }

        stage('Push DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        sh "docker login -u ${USER} -p ${PASS}"
                        sh "./ci-cd/scripts/push.sh ${TAG}"
                    }
                }
            }
        }

        stage('Deploy (Ansible/K8s)') {
            steps {
                echo "🚀 Deploying to environment using Ansible/Kubernetes..."
                // Bước này sẽ được hoàn thiện ở các giai đoạn sau của lộ trình
            }
        }
    }

    post {
        always {
            echo "--- Pipeline completed ---"
        }
        success {
            echo "--- Build successful! ---"
        }
        failure {
            echo "--- Build failed. Please check logs. ---"
        }
    }
}
