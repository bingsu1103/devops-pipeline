pipeline {
    agent any

    environment {
        PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-creds'
        
        // ENV_TARGET must be provided by application.properties
        ENV_TARGET = ''
        TAG = "build-${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Load Configuration') {
    steps {
        script {
            echo "--- [Configuration as Code] Bắt đầu nạp cấu hình ---"
            
            // Kiểm tra file tồn tại trước khi đọc
            if (!fileExists('application.properties')) {
                error "Không tìm thấy file application.properties tại thư mục gốc!"
            }

            // Sử dụng readProperties thay vì tự parse thủ công
            def rootProps = readProperties file: 'application.properties'
            
            // Lấy ENV_TARGET, trim triệt để các ký tự xuống dòng \r hoặc \n
            env.ENV_TARGET = rootProps['ENV_TARGET']?.trim()

            if (!env.ENV_TARGET) {
                // Debug: In ra toàn bộ key để xem Jenkins thực sự đọc được gì
                echo "Nội dung đọc được: ${rootProps}"
                error "ENV_TARGET is required. Set it in application.properties to 'dev' or 'prod'."
            }

            echo "Môi trường mục tiêu: ${env.ENV_TARGET}"

            // Nạp cấu hình chi tiết
            def envConfigFile = "infrastructure/envs/${env.ENV_TARGET}/pipeline.properties"
            if (!fileExists(envConfigFile)) {
                error "Không tìm thấy file cấu hình tại: ${envConfigFile}"
            }

            def props = readProperties file: envConfigFile
            
            // Áp dụng cấu hình (Dùng toán tử Elvis để set default)
            env.B_PORT       = props['BACKEND_PORT'] ?: '7070'
            env.F_PORT       = props['FRONTEND_PORT'] ?: '3000'
            env.DOCKER_USER  = props['DOCKER_USER'] ?: 'bingsu1103'
            env.AWS_SSH_KEY  = props['AWS_SSH_KEY_NAME'] ?: 'AWS_key_pair'
            
            // Các config khác giữ nguyên logic của bạn...
            env.SSL_ENABLED  = props['SSL_ENABLED'] ?: 'false'
            echo "--- Cấu hình hoàn tất cho môi trường: ${env.ENV_TARGET} ---"
        }
    }
}

        stage('Build Artifacts') {
            steps {
                dir('backend') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Infrastructure Provisioning') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'rds-db-password', variable: 'DB_PASS')
                ]) {
                    dir("infrastructure/envs/${ENV_TARGET}") {
                        sh 'terraform init'
                        sh "terraform apply -var='db_password=\$DB_PASS' -var='backend_port=${B_PORT}' -var='frontend_port=${F_PORT}' -var='ssh_key=${AWS_SSH_KEY}' -auto-approve"
                        
                        script {
                            // Extract IP from Terraform Output
                            def backend_ip = sh(script: "terraform output -raw backend_public_ip", returnStdout: true).trim()
                            def frontend_ip = sh(script: "terraform output -raw frontend_public_ip", returnStdout: true).trim()
                            def rds_endpoint_full = sh(script: "terraform output -raw rds_endpoint", returnStdout: true).trim()
                            def rds_host = rds_endpoint_full.split(":")[0]

                            env.BACKEND_IP = backend_ip
                            env.FRONTEND_IP = frontend_ip
                            env.RDS_HOST = rds_host

                            echo "--- Service Access Information ---"
                            echo "Backend: http://${env.BACKEND_IP}:${B_PORT}"
                            echo "Frontend: http://${env.FRONTEND_IP}:${F_PORT}"
                            echo "----------------------------------"

                            // Generate Ansible inventory from template
                            def inventoryTplPath = "${env.WORKSPACE}/ansible/inventory/${ENV_TARGET}.ini.example"
                            def inventoryTpl = readFile(inventoryTplPath)
                            def activeInventory = inventoryTpl
                                .replace("{{ BACKEND_IP }}", env.BACKEND_IP)
                                .replace("{{ FRONTEND_IP }}", env.FRONTEND_IP)
                                .replace("{{ RDS_HOST }}", env.RDS_HOST)
                            
                            writeFile(file: "${env.WORKSPACE}/ansible/inventory/${ENV_TARGET}.ini", text: activeInventory)
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    // Tạo thư mục config tạm để tránh lỗi docker-credential-desktop trên Mac
                    sh "mkdir -p .docker_config && echo '{}' > .docker_config/config.json"
                    sh "chmod +x ci-cd/scripts/*.sh"
                    
                    // Tính toán API URL dựa trên Domain (Nếu có)
                    def protocol = (env.SSL_ENABLED == 'true') ? 'https' : 'http'
                    def api_url = (env.BACKEND_DOMAIN_NAME != '') ? "${protocol}://${env.BACKEND_DOMAIN_NAME}" : "http://${env.BACKEND_IP}:${B_PORT}"
                    env.NEXT_PUBLIC_API_URL = api_url
                    
                    withEnv([
                        "DOCKER_CONFIG=${env.WORKSPACE}/.docker_config",
                        "NEXT_PUBLIC_API_URL=${env.NEXT_PUBLIC_API_URL}",
                        "DOCKERHUB_USER=${DOCKER_USER}"
                    ]) {
                        sh "./ci-cd/scripts/build.sh ${TAG}"
                    }
                }
            }
        }

        stage('Push DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        withEnv(["DOCKER_CONFIG=${env.WORKSPACE}/.docker_config"]) {
                            // Clear proxies for docker login to bypass 'HTTP response to HTTPS client' error if proxy is misconfigured/intercepting
                            sh 'HTTP_PROXY="" HTTPS_PROXY="" docker login -u $USER -p $PASS'
                            withEnv(["DOCKERHUB_USER=${env.DOCKER_USER}"]) {
                                sh "HTTP_PROXY='' HTTPS_PROXY='' ./ci-cd/scripts/push.sh ${TAG}"
                            }
                        }
                    }
                }
            }
        }

        stage('Configuration & Deploy') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    withCredentials([string(credentialsId: 'rds-db-password', variable: 'DB_PASS')]) {
                        script {
                            dir('ansible') {
                                sh "ansible-playbook -i inventory/${ENV_TARGET}.ini playbooks/setup.yml"

                                def extraVars = "image_tag=${TAG} " +
                                               "docker_user=${DOCKER_USER} " +
                                               "b_port=${B_PORT} " +
                                               "f_port=${F_PORT} " +
                                               "db_password=\$DB_PASS " +
                                               "frontend_domain_name=${env.FRONTEND_DOMAIN_NAME} " +
                                               "backend_domain_name=${env.BACKEND_DOMAIN_NAME} " +
                                               "ssl_enabled=${env.SSL_ENABLED} " +
                                               "certbot_email=${env.CERTBOT_EMAIL} " +
                                               "backend_host=${env.BACKEND_IP} " +
                                               "next_public_api_url=${env.NEXT_PUBLIC_API_URL}"

                                sh "ansible-playbook -i inventory/${ENV_TARGET}.ini playbooks/deploy.yml --extra-vars '${extraVars}'"
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                def envLabel = env.ENV_TARGET ?: 'unknown'
                echo "--- Pipeline for ${envLabel} environment completed ---"
            }
        }
    }
}

